#pragma comment(lib, "ntdll.lib")

typedef NTSTATUS(NTAPI* pNtCreateFile)(
    PHANDLE FileHandle,
    ACCESS_MASK DesiredAccess,
    POBJECT_ATTRIBUTES ObjectAttributes,
    PIO_STATUS_BLOCK IoStatusBlock,
    PLARGE_INTEGER AllocationSize,
    ULONG FileAttributes,
    ULONG ShareAccess,
    ULONG CreateDisposition,
    ULONG CreateOptions,
    PVOID EaBuffer,
    ULONG EaLength
);

DWORD ExtractSyscallNumber(const char* funcName)
{
    HMODULE ntdll = GetModuleHandleA("ntdll.dll");
    if (!ntdll)
    {
        printf("[-] Khong the lay ntdll handle!\n");
        return (DWORD)-1;
    }

    BYTE* func = (BYTE*)GetProcAddress(ntdll, funcName);
    if (!func)
    {
        printf("[-] Khong tim thay ham: %s\n", funcName);
        return (DWORD)-1;
    }

    if (func[0] != 0x4C || func[1] != 0x8B || func[2] != 0xD1 || func[3] != 0xB8)
    {
        printf("[!] %s co ve bi HOOK! Byte dau: %02X %02X %02X %02X\n",
            funcName, func[0], func[1], func[2], func[3]);
    }

    DWORD syscallNum = *(DWORD*)(func + 4);

    printf("[+] %s -> Syscall number: 0x%02X (decimal: %d)\n",
        funcName, syscallNum, syscallNum);

    return syscallNum;
}

pNtCreateFile BuildSyscallStub(DWORD syscallNumber)
{
    BYTE stub[] = {
        0x4C, 0x8B, 0xD1,
        0xB8, 0x00, 0x00, 0x00, 0x00,
        0x0F, 0x05,
        0xC3
    };

    *(DWORD*)(stub + 4) = syscallNumber;

    LPVOID execMem = VirtualAlloc(
        NULL,
        sizeof(stub),
        MEM_COMMIT | MEM_RESERVE,
        PAGE_EXECUTE_READWRITE
    );

    if (!execMem)
    {
        printf("[-] VirtualAlloc that bai! Loi: %lu\n", GetLastError());
        return NULL;
    }

    memcpy(execMem, stub, sizeof(stub));

    printf("[*] Syscall stub da duoc xay dung tai: 0x%p\n", execMem);
    printf("[*] Noi dung stub (11 bytes): ");
    for (int i = 0; i < 11; i++)
    {
        printf("%02X ", ((BYTE*)execMem)[i]);
    }
    printf("\n");

    return (pNtCreateFile)execMem;
}

